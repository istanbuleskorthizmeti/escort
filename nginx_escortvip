    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-DRKCNAY-Node "Hydra-Alpha" always;

    # 🧊 CENTRAL MEDIA / CDN PATHS
    location ^~ /_media/vitrin/ {
        alias /var/www/cdn/vitrin/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
        add_header X-Served-By "Hydra-CDN-Master";
    }

    # 🕸️ HYDRA SEO IMAGE DOMINATION (URL MASKING)
    # Serves symlinked SEO images directly from the CDN
    location ~* /(?:istanbul-vip-escort-bayan|kaporasiz-escort-resimleri|en-iyi-escort-profilleri|vip-escort-ilan)-[0-9]+\.webp$ {
        root /var/www/cdn/vitrin;
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, no-transform";
        add_header X-Served-By "Hydra-SEO-Proxy";
    }

    location ^~ /assets/img/ {
        alias /var/www/cdn/vitrin/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    # 🌊 NEXT.JS STATIC FILES
    location /_next/static/ {
        alias /root/esc/.next/static/;
        expires 30d;
        access_log off;
    }

    location /_next/ {
        proxy_pass http://drkcnay_nextjs;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    location / {
        proxy_pass http://drkcnay_nextjs;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
